{
  "name": "ecommerce-next-gaming",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:reset": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ports = @(3000,3001); foreach ($port in $ports) { $procIds = Get-NetTCPConnection -LocalPort $port -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique; foreach ($procId in $procIds) { Stop-Process -Id $procId -Force -ErrorAction SilentlyContinue } }; if (Test-Path '.next') { Remove-Item -LiteralPath '.next' -Recurse -Force }; npm run dev\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "enrich:games": "node scripts/enrich-games-from-rawg.mjs",
    "market:sync:dry": "node scripts/sync-market-products.mjs",
    "market:sync": "node scripts/sync-market-products.mjs --write",
    "e2e:checkout": "node scripts/e2e-checkout.mjs",
    "e2e:stripe": "node scripts/e2e-stripe.mjs",
    "e2e:paypal": "node scripts/e2e-paypal.mjs",
    "e2e:all": "npm run e2e:checkout && npm run e2e:stripe && npm run e2e:paypal",
    "e2e:all:continue": "node scripts/e2e-all-continue.mjs",
    "test:all": "npm run test:unit && npm run build && npm run e2e:all",
    "postinstall": "prisma generate",
    "stripe:webhook:listen": "stripe listen --forward-to localhost:3000/api/payments/stripe/webhook",
    "stripe:webhook:test:checkout": "stripe trigger checkout.session.completed",
    "stripe:webhook:test:async": "stripe trigger checkout.session.async_payment_succeeded"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "next": "16.2.7",
    "nodemailer": "^8.0.1",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@netlify/plugin-nextjs": "^5.15.11",
    "@types/node": "25.9.1",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.7",
    "prisma": "^6.10.1",
    "sass": "1.100.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
