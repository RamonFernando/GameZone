# PostgreSQL (Neon). Copia ambas URLs desde el dashboard de Neon > Connection Details.
# DATABASE_URL         = pooled connection  (para la app en produccion)
# DATABASE_URL_UNPOOLED = direct connection (para prisma migrate)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-west-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.eu-west-1.aws.neon.tech/neondb?sslmode=require"
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-for-production-at-least-24-chars
# Clave para cifrar secretos TOTP en reposo (AES-256). Generar con:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
ENABLE_MASTER_ADMIN=true
MASTER_ADMIN_USERNAME=admin
MASTER_ADMIN_EMAIL=admin@local.test
MASTER_ADMIN_PASSWORD=admin
CRON_SECRET=change-this-random-secret-at-least-16-chars

# SMTP real (produccion): si estos valores existen, se usa este servidor.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@gamezone.local

# Branding opcional para correos transaccionales
MAIL_BRAND_NAME=GameZone Store
MAIL_SUPPORT_EMAIL=support@gamezone.local
MAIL_LOGO_URL=

# Stripe (tarjetas + wallets como Google Pay según dispositivo)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal Checkout
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=

# OAuth social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Si Meta usa Facebook Login por configuracion/caso de uso, pega aqui el Configuration ID.
FACEBOOK_CONFIG_ID=
# FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/oauth/facebook/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# TWITTER_REDIRECT_URI=http://localhost:3000/api/auth/oauth/twitter/callback

# Metadata externa de juegos
RAWG_API_KEY=
