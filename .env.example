DATABASE_URL="file:./dev.db"
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-for-production-at-least-24-chars
ENABLE_MASTER_ADMIN=true
MASTER_ADMIN_USERNAME=admin
MASTER_ADMIN_EMAIL=admin@local.test
MASTER_ADMIN_PASSWORD=admin

# SMTP real (produccion): si estos valores existen, se usa este servidor.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@gamezone.local

# Branding opcional para correos transaccionales
MAIL_BRAND_NAME=GameZone Store
MAIL_SUPPORT_EMAIL=support@gamezone.local
MAIL_LOGO_URL=

# Stripe (tarjetas + wallets como Google Pay según dispositivo)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal Checkout
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=

# OAuth social login
