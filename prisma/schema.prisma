generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id                         String         @id @default(uuid())
  name                       String
  email                      String         @unique
  passwordHash               String
  role                       UserRole       @default(USER)
  isVerified                 Boolean        @default(false)
  verificationTokenHash      String?        @unique
  verificationTokenExpiresAt DateTime?
  passwordResetTokenHash     String?        @unique
  passwordResetTokenExpiresAt DateTime?
  avatarUrl                  String?
  phone                      String?
  addressLine1               String?
  city                       String?
  postalCode                 String?
  country                    String?
  province                   String?
  // --- Campos para 2FA por código (email/SMS) ---
  twoFactorEnabled           Boolean        @default(false)
  twoFactorChannel           String?        // "email" | "sms" (por ahora usaremos email)
  twoFactorCodeHash          String?        @unique
  twoFactorCodeExpiresAt     DateTime?
  // --- Push-style MFA (aprobación de inicio de sesión) ---
  pushAuthEnabled            Boolean        @default(false)
  // --- 2FA con app TOTP (Google Authenticator, Authy, etc.) ---
  totpEnabled                Boolean        @default(false)
  totpSecret                 String?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  sessions                   Session[]
  orders                     Order[]
  userPermissions            UserPermission[]
  likes                      ProductLike[]
  cartItems                  UserCartItem[]
  pushDevices                PushDevice[]
  loginChallenges            LoginChallenge[]
}

model PushDevice {
  id         String   @id @default(cuid())
  userId     String
  name       String
  userAgent  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginChallenge {
  id                  String   @id @default(cuid())
  userId              String
  status              String   @default("pending") // pending | approved | denied | expired
  tokenHash           String   @unique
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime @default(now())
  resolvedAt          DateTime?
  expiresAt           DateTime
  approvedByDeviceId  String?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model Product {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  description     String   @db.Text
  coverImage      String
  platform        String   @default("PC")
  region          String   @default("EUROPA")
  storeLabel      String   @default("Steam")
  cardSubtitle    String   @default("Código digital oficial")
  longDescription String?  @db.Text
  rawgId          Int?
  rawgSlug        String?
  releaseDate     DateTime?
  developer       String?
  publisher       String?
  genresJson      String   @default("[]")
  platformsJson   String   @default("[]")
  tagsJson        String   @default("[]")
  storesJson      String   @default("[]")
  screenshotsJson String   @default("[]")
  backgroundImage String?
  website         String?
  esrbRating      String?
  metacritic      Int?
  rating          Float?
  ratingsCount    Int      @default(0)
  playtimeHours   Int?
  requirements    String?  @db.Text
  metadataSource  String?
  metadataUpdatedAt DateTime?
  priceOriginal   Float
  discountPercent Int      @default(0)
  cashbackPercent Int      @default(0)
  likesCount      Int      @default(0)
  stock           Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  likes ProductLike[]
  cartItems UserCartItem[]

  @@index([isActive, createdAt])
  @@index([rawgId])
}

model UserCartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model ProductLike {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model Session {
  id         String   @id
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  totalAmount Float
  currency    String      @default("EUR")
  status      String      @default("pending")
  paymentProvider String?
  paymentReference String?
  paidAt DateTime?
  confirmationEmailSentAt DateTime?
  refundedAt DateTime?
  refundedByUserId String?
  refundReason String?
  refundReference String?
  refundEmailSentAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       OrderItem[]

  @@index([userId, createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  gameSlug  String
  title     String
  unitPrice Float
  quantity  Int
  subtotal  Float
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  description     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         UserRole
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([permissionId])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  granted      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model CatalogSyncRun {
  id                String    @id @default(cuid())
  status            String    @default("running")
  mode              String    @default("write")
  triggeredBy       String
  triggeredByUserId String?
  sourcesJson       String    @default("[]")
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  createdCount      Int       @default(0)
  updatedCount      Int       @default(0)
  skippedCount      Int       @default(0)
  fallbackUsed      Boolean   @default(false)
  dryRun            Boolean   @default(false)
  error             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, startedAt])
  @@index([startedAt])
}
