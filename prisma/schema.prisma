generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id                         String   @id @default(uuid())
  name                       String
  email                      String   @unique
  passwordHash               String
  role                       UserRole @default(USER)
  isVerified                 Boolean  @default(false)
  verificationTokenHash      String?  @unique
  verificationTokenExpiresAt DateTime?
  avatarUrl                  String?
  phone                      String?
  addressLine1               String?
  city                       String?
  postalCode                 String?
  country                    String?
  province                   String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  sessions                   Session[]
  orders                     Order[]
  userPermissions            UserPermission[]
  likes                      ProductLike[]
}

model Product {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  description     String
  coverImage      String
  platform        String   @default("PC")
  region          String   @default("EUROPA")
  storeLabel      String   @default("Steam")
  cardSubtitle    String   @default("Código digital oficial")
  priceOriginal   Float
  discountPercent Int      @default(0)
  cashbackPercent Int      @default(0)
  likesCount      Int      @default(0)
  stock           Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  likes ProductLike[]

  @@index([isActive, createdAt])
}

model ProductLike {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model Session {
  id         String   @id
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  totalAmount Float
  currency    String      @default("EUR")
  status      String      @default("pending")
  paymentProvider String?
  paymentReference String?
  paidAt DateTime?
  confirmationEmailSentAt DateTime?
  refundedAt DateTime?
  refundedByUserId String?
  refundReason String?
  refundReference String?
  refundEmailSentAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       OrderItem[]

  @@index([userId, createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  gameSlug  String
  title     String
  unitPrice Float
  quantity  Int
  subtotal  Float
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  description     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         UserRole
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([permissionId])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  granted      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}
